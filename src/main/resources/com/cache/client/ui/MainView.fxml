<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cache.client.ui.MainController" spacing="10">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- ============================================================
         [组员B] 区域1: 连接管理栏
         ============================================================ -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Server:"/>
        <TextField fx:id="serverHostField" promptText="127.0.0.1" prefWidth="150"/>
        <Label text="Port:"/>
        <TextField fx:id="serverPortField" promptText="6379" prefWidth="80"/>
        <Button text="Connect" onAction="#onConnect"/>
        <Button text="Disconnect" onAction="#onDisconnect"/>
        <Label fx:id="connectionStatusLabel" text="● Disconnected" style="-fx-text-fill: gray;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Stats" onAction="#onShowStats"/>
    </HBox>

    <Separator/>

    <!-- ============================================================
         [组员A] 区域2: 输入 + CRUD 操作栏
         ============================================================ -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="keyField" promptText="Key" prefWidth="200"/>
        <TextField fx:id="valueField" promptText="Value" prefWidth="300"/>
        <TextField fx:id="ttlField" promptText="TTL (s)" prefWidth="100"/>
        <Button text="Add / Update" onAction="#onAdd"/>
        <Button text="Delete" onAction="#onDelete"/>
        <Button text="Clear All" onAction="#onClearAll"/>
    </HBox>

    <!-- ============================================================
         [组员C] 区域3: 搜索 + 批量操作栏
         ============================================================ -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search keys (supports *, ?)..." prefWidth="300" HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#onSearch"/>
        <Button text="Show All" onAction="#onShowAll"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Export JSON" onAction="#onExportJson"/>
        <Button text="Export CSV" onAction="#onExportCsv"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>

    <!-- ============================================================
         [组员A] 区域4: 缓存条目表格
         ============================================================ -->
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="keyColumn" text="Key" prefWidth="200"/>
            <TableColumn fx:id="valueColumn" text="Value" prefWidth="350"/>
            <TableColumn fx:id="ttlColumn" text="TTL (s)" prefWidth="80"/>
            <TableColumn fx:id="createTimeColumn" text="Create Time" prefWidth="180"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- ============================================================
         [组员B] 区域5: 统计面板
         ============================================================ -->
    <HBox spacing="20" style="-fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8;">
        <Label text="Stats —"/>
        <Label fx:id="statEntriesLabel" text="Entries: -"/>
        <Label fx:id="statHitRateLabel" text="Hit Rate: -"/>
        <Label fx:id="statMemoryLabel" text="Memory: -"/>
        <Label fx:id="statUptimeLabel" text="Uptime: -"/>
    </HBox>

    <!-- ============================================================
         状态栏
         ============================================================ -->
    <Label fx:id="statusLabel" text="Ready"/>
</VBox>
